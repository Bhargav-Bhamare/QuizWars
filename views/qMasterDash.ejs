<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚔️ Trojans Quiz Arena — Control Room</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --red: #ff2244;
  --red-glow: rgba(255,34,68,0.5);
  --blue: #00d4ff;
  --blue-glow: rgba(0,212,255,0.4);
  --gold: #ffd700;
  --gold-glow: rgba(255,215,0,0.4);
  --green: #00ff88;
  --green-glow: rgba(0,255,136,0.4);
  --orange: #ff8800;
  --bg-deep: #020810;
  --bg-panel: rgba(6,14,36,0.88);
  --bg-glass: rgba(0,180,255,0.035);
  --border-blue: rgba(0,212,255,0.2);
  --border-red: rgba(255,34,68,0.3);
  --border-gold: rgba(255,215,0,0.25);
  --text-primary: #e8f4ff;
  --text-dim: #3a6080;
  --font-hud: 'Orbitron', monospace;
  --font-body: 'Rajdhani', sans-serif;
  --font-mono: 'Share Tech Mono', monospace;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  width: 100%; height: 100%;
  background: var(--bg-deep);
  color: var(--text-primary);
  font-family: var(--font-body);
  overflow: hidden;
}

/* ─── SCANLINES ─────────────────────────── */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 1;
  pointer-events: none;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
}

/* ─── ENTRY SCREEN ──────────────────────── */
#entry {
  position: fixed; inset: 0; z-index: 9999;
  background: #000;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 1rem;
  animation: entryDismiss 0.7s ease 3.6s forwards;
}
.entry-title {
  font-family: var(--font-hud);
  font-size: clamp(1.5rem, 4vw, 3.5rem);
  font-weight: 900;
  letter-spacing: 0.15em;
  color: var(--gold);
  text-shadow: 0 0 30px var(--gold), 0 0 80px var(--gold-glow);
  text-align: center;
  animation: entryIn 0.8s ease 0.2s both;
}
.entry-sub {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  letter-spacing: 0.4em;
  color: var(--red);
  text-shadow: 0 0 10px var(--red);
  animation: entryIn 0.6s ease 0.7s both;
}
.entry-bar-wrap {
  width: 340px; margin-top: 1.5rem;
  animation: entryIn 0.5s ease 1.2s both;
}
.entry-bar-track {
  height: 4px; background: #111;
  border: 1px solid #222; border-radius: 2px; overflow: hidden;
}
.entry-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--red), var(--gold), var(--blue));
  width: 0; border-radius: 2px;
  animation: loadFill 2.2s ease 1.3s forwards;
}
.entry-status {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: #334;
  letter-spacing: 0.2em;
  margin-top: 0.5rem;
  text-align: center;
  animation: entryIn 0.5s ease 1.4s both;
}
@keyframes entryIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
@keyframes entryDismiss { to { opacity:0; pointer-events:none; } }
@keyframes loadFill { to { width: 100%; } }

/* ─── CANVAS ────────────────────────────── */
#bg-canvas {
  position: fixed; inset: 0; z-index: 0;
  pointer-events: none;
}

/* ─── VIGNETTE ──────────────────────────── */
#vignette {
  position: fixed; inset: 0; z-index: 2;
  pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 35%, rgba(0,0,0,0.88) 100%);
}

/* ─── LAUNCH OVERLAY ────────────────────── */
#launch-overlay {
  position: fixed; inset: 0; z-index: 800;
  display: none;
  align-items: center; justify-content: center;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(6px);
}
#launch-overlay.visible { display: flex; }
.launch-anim {
  text-align: center;
  animation: launchPop 0.5s cubic-bezier(0.16,1,0.3,1);
}
.launch-ring {
  width: 160px; height: 160px;
  border: 3px solid var(--gold);
  border-radius: 50%;
  box-shadow: 0 0 40px var(--gold), inset 0 0 40px rgba(255,215,0,0.1);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.5rem;
  animation: launchSpin 1s linear infinite;
  font-size: 3rem;
}
@keyframes launchSpin { to { transform: rotate(360deg); } }
.launch-txt {
  font-family: var(--font-hud);
  font-size: 1.4rem;
  font-weight: 900;
  color: var(--gold);
  text-shadow: 0 0 20px var(--gold);
  letter-spacing: 0.2em;
  animation: launchBlink 0.5s step-end infinite;
}
@keyframes launchBlink { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes launchPop { from{transform:scale(0.6);opacity:0} to{transform:scale(1);opacity:1} }

/* ─── APP SHELL ─────────────────────────── */
#app {
  position: relative; z-index: 10;
  display: grid;
  grid-template-rows: 58px 1fr 48px;
  grid-template-columns: 260px 1fr 280px;
  height: 100vh;
  opacity: 0;
  animation: fadeIn 0.8s ease 4s forwards;
}
@keyframes fadeIn { to{opacity:1} }

/* ─── NAVBAR ────────────────────────────── */
#navbar {
  grid-column: 1/-1; grid-row: 1;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 1.4rem;
  background: linear-gradient(90deg, rgba(255,215,0,0.06), rgba(6,14,36,0.95), rgba(0,212,255,0.05));
  border-bottom: 1px solid var(--border-gold);
  z-index: 20; position: relative;
}
#navbar::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, var(--gold), var(--red) 40%, var(--blue) 60%, var(--gold));
  background-size: 300% 100%;
  animation: navBorderFlow 5s linear infinite;
}
@keyframes navBorderFlow { 0%{background-position:0%} 100%{background-position:300%} }

.nav-logo {
  font-family: var(--font-hud);
  font-size: 1rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  display: flex; align-items: center; gap: 0.5rem;
  white-space: nowrap;
}
.logo-trophy { color: var(--gold); text-shadow: 0 0 15px var(--gold); }
.logo-main { color: var(--text-primary); }
.logo-sub { color: var(--red); text-shadow: 0 0 10px var(--red); font-size: 0.85rem; }

.nav-status-pill {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.3rem 0.9rem;
  border: 1px solid;
  font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em;
  clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
  transition: all 0.4s;
}
.nav-status-pill.offline {
  border-color: rgba(100,100,100,0.4);
  color: #556; background: rgba(0,0,0,0.3);
}
.nav-status-pill.online {
  border-color: var(--green);
  color: var(--green);
  background: rgba(0,255,136,0.06);
  box-shadow: 0 0 15px rgba(0,255,136,0.15);
  animation: onlinePulse 2s ease-in-out infinite;
}
.nav-status-pill.live {
  border-color: var(--red);
  color: var(--red);
  background: rgba(255,34,68,0.08);
  box-shadow: 0 0 15px rgba(255,34,68,0.2);
  animation: livePulse 1s ease-in-out infinite;
}
@keyframes onlinePulse { 0%,100%{box-shadow:0 0 10px rgba(0,255,136,0.15)} 50%{box-shadow:0 0 25px rgba(0,255,136,0.3)} }
@keyframes livePulse { 0%,100%{box-shadow:0 0 10px rgba(255,34,68,0.2)} 50%{box-shadow:0 0 30px rgba(255,34,68,0.4)} }

.status-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: currentColor;
  animation: dotBlink 1s step-end infinite;
}
@keyframes dotBlink { 0%,100%{opacity:1} 50%{opacity:0.2} }

.nav-right {
  display: flex; align-items: center; gap: 1rem;
}
.admin-name {
  font-family: var(--font-hud);
  font-size: 0.72rem;
  color: var(--gold);
  text-shadow: 0 0 8px var(--gold-glow);
  letter-spacing: 0.1em;
}
.admin-avatar {
  width: 34px; height: 34px; border-radius: 50%;
  border: 2px solid var(--gold);
  box-shadow: 0 0 14px var(--gold-glow);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
  background: linear-gradient(135deg, #1a1000, #2a1a00);
  animation: avatarGlow 3s ease-in-out infinite;
}
@keyframes avatarGlow {
  0%,100%{box-shadow:0 0 14px var(--gold-glow)}
  50%{box-shadow:0 0 28px var(--gold), 0 0 50px var(--gold-glow)}
}
.btn-nav {
  font-family: var(--font-hud);
  font-size: 0.62rem; letter-spacing: 0.15em;
  padding: 0.38rem 0.85rem;
  background: transparent; border: 1px solid var(--border-red);
  color: var(--red); cursor: pointer;
  clip-path: polygon(5px 0, 100% 0, calc(100% - 5px) 100%, 0 100%);
  transition: all 0.2s; text-transform: uppercase;
}
.btn-nav:hover { background: var(--red-glow); color: #fff; box-shadow: 0 0 15px var(--red-glow); }

/* ─── LEFT COLUMN ─────────────────────── */
#left-col {
  grid-column: 1; grid-row: 2;
  display: flex; flex-direction: column;
  border-right: 1px solid var(--border-blue);
  overflow: hidden;
}

/* CONTROL PANEL */
#ctrl-panel {
  padding: 1rem 0.9rem 0.8rem;
  border-bottom: 1px solid var(--border-blue);
  background: linear-gradient(180deg, rgba(255,215,0,0.04), transparent);
}

.section-hdr {
  font-family: var(--font-hud);
  font-size: 0.58rem; letter-spacing: 0.28em;
  color: var(--gold); text-shadow: 0 0 6px var(--gold-glow);
  margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.5rem;
}
.section-hdr::before {
  content: ''; flex: 0 0 20px; height: 1px;
  background: var(--gold); box-shadow: 0 0 4px var(--gold);
}
.section-hdr::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--gold-glow), transparent);
}

/* Game State Indicator */
#game-state-display {
  background: rgba(0,0,0,0.4);
  border: 1px solid var(--border-blue);
  padding: 0.8rem;
  margin-bottom: 0.8rem;
  position: relative;
  overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
#game-state-display::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, var(--blue), transparent);
}
.state-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; }
.state-row:last-child { margin-bottom: 0; }
.state-lbl { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-dim); letter-spacing: 0.15em; }
.state-val { font-family: var(--font-hud); font-size: 0.85rem; font-weight: 700; }
.val-waiting { color: var(--text-dim); }
.val-live { color: var(--green); text-shadow: 0 0 8px var(--green); animation: liveFlicker 2s step-end infinite; }
.val-finished { color: var(--red); text-shadow: 0 0 8px var(--red); }
@keyframes liveFlicker { 0%,95%,100%{opacity:1} 96%{opacity:0.5} 97%{opacity:1} 98%{opacity:0.6} }

.ctrl-btns { display: flex; flex-direction: column; gap: 0.55rem; }

.arena-btn {
  font-family: var(--font-hud);
  font-size: 0.68rem; letter-spacing: 0.1em;
  padding: 0.7rem 0.8rem;
  border: none; cursor: pointer;
  position: relative; overflow: hidden;
  transition: all 0.2s cubic-bezier(0.16,1,0.3,1);
  clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
  text-align: center; text-transform: uppercase;
  width: 100%;
}
.arena-btn::after {
  content: '';
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.3);
  width: 6px; height: 6px;
  left: var(--rx,50%); top: var(--ry,50%);
  transform: translate(-50%,-50%) scale(0); opacity: 0;
  pointer-events: none;
}
.arena-btn.rippling::after { animation: ripple 0.5s ease-out forwards; }
@keyframes ripple { to{transform:translate(-50%,-50%) scale(50);opacity:0} }

.btn-start {
  background: linear-gradient(135deg, #cc1c38, #88001a);
  color: #fff;
  box-shadow: 0 0 20px var(--red-glow), inset 0 1px 0 rgba(255,255,255,0.1);
  font-size: 0.82rem; font-weight: 700;
}
.btn-start:hover:not(:disabled) { box-shadow: 0 0 40px var(--red), 0 0 80px var(--red-glow); transform: scale(1.02); }
.btn-start:disabled { opacity: 0.35; cursor: not-allowed; }

.btn-pause {
  background: linear-gradient(135deg, #aa7700, #664400);
  color: var(--gold);
  box-shadow: 0 0 10px var(--gold-glow);
}
.btn-pause:hover:not(:disabled) { box-shadow: 0 0 25px var(--gold); transform: scale(1.02); color: #fff; }
.btn-pause:disabled { opacity: 0.3; cursor: not-allowed; }

.btn-end {
  background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(0,0,0,0.4));
  color: var(--blue);
  border: 1px solid var(--border-blue);
  box-shadow: 0 0 8px var(--blue-glow);
}
.btn-end:hover:not(:disabled) { box-shadow: 0 0 20px var(--blue); color: #fff; }
.btn-end:disabled { opacity: 0.3; cursor: not-allowed; }

/* QUESTION BANK */
#qbank-section {
  flex: 1;
  display: flex; flex-direction: column;
  overflow: hidden;
  padding: 0.8rem 0.9rem 0;
}
#qbank-list {
  flex: 1; overflow-y: auto; padding-right: 4px;
  display: flex; flex-direction: column; gap: 0.45rem;
  padding-bottom: 0.5rem;
}
#qbank-list::-webkit-scrollbar { width: 3px; }
#qbank-list::-webkit-scrollbar-thumb { background: var(--border-blue); border-radius: 2px; }

.qb-card {
  background: rgba(0,0,0,0.25);
  border: 1px solid var(--border-blue);
  padding: 0.6rem 0.7rem;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
}
.qb-card:hover { border-color: var(--blue); transform: translateX(3px); box-shadow: 0 0 12px var(--blue-glow); }
.qb-card.active-q { border-color: var(--gold); background: rgba(255,215,0,0.05); box-shadow: 0 0 15px var(--gold-glow); }
.qb-card.deleting { animation: qbDelete 0.4s ease forwards; }
@keyframes qbDelete { to { opacity: 0; transform: translateX(-20px); } }

.qb-text {
  font-family: var(--font-body); font-size: 0.78rem; font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 0.35rem;
}
.qb-meta { display: flex; align-items: center; gap: 0.5rem; }
.diff-badge {
  font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.1em;
  padding: 1px 7px; border-radius: 1px;
  border: 1px solid;
}
.diff-easy { border-color: var(--green); color: var(--green); background: rgba(0,255,136,0.07); }
.diff-medium { border-color: var(--gold); color: var(--gold); background: rgba(255,215,0,0.07); }
.diff-hard { border-color: var(--red); color: var(--red); background: rgba(255,34,68,0.07); }

.qb-actions { display: flex; gap: 0.35rem; margin-left: auto; }
.qb-btn {
  font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.05em;
  padding: 2px 8px; background: transparent; cursor: pointer;
  border-radius: 1px; transition: all 0.15s; border: 1px solid;
}
.qb-btn-edit { border-color: var(--border-blue); color: var(--blue); }
.qb-btn-edit:hover { background: rgba(0,212,255,0.1); box-shadow: 0 0 8px var(--blue-glow); }
.qb-btn-del { border-color: var(--border-red); color: var(--red); }
.qb-btn-del:hover { background: rgba(255,34,68,0.1); box-shadow: 0 0 8px var(--red-glow); }

/* ─── CENTER PANEL ──────────────────────── */
#center-col {
  grid-column: 2; grid-row: 2;
  display: flex; flex-direction: column;
  padding: 1rem 1.2rem;
  gap: 0.9rem;
  overflow-y: auto;
  position: relative;
}
#center-col::-webkit-scrollbar { width: 3px; }
#center-col::-webkit-scrollbar-thumb { background: var(--border-blue); }

/* Arena floor glow */
#center-col::before {
  content: '';
  position: fixed;
  bottom: 48px; left: 260px; right: 280px; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), var(--red), var(--gold), transparent);
  box-shadow: 0 0 20px var(--gold);
  animation: floorGlow 2.5s ease-in-out infinite alternate;
  pointer-events: none; z-index: 5;
}
@keyframes floorGlow { from{opacity:0.3} to{opacity:0.9} }

/* STATS GRID */
#stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.65rem;
}

.stat-box {
  background: var(--bg-panel);
  border: 1px solid var(--border-blue);
  padding: 0.8rem;
  position: relative; overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  transition: all 0.3s;
}
.stat-box:hover { border-color: var(--blue); box-shadow: 0 0 15px var(--blue-glow); }
.stat-box::after {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, var(--blue), transparent);
}
.stat-box-icon { font-size: 1.2rem; margin-bottom: 0.3rem; }
.stat-box-val {
  font-family: var(--font-hud); font-size: 1.6rem; font-weight: 900;
  color: var(--blue); text-shadow: 0 0 10px var(--blue-glow); line-height: 1;
}
.stat-box-lbl {
  font-family: var(--font-mono); font-size: 0.58rem; color: var(--text-dim);
  letter-spacing: 0.15em; margin-top: 0.2rem;
}
.stat-box.gold .stat-box-val { color: var(--gold); text-shadow: 0 0 10px var(--gold-glow); }
.stat-box.red .stat-box-val { color: var(--red); text-shadow: 0 0 10px var(--red-glow); }
.stat-box.green .stat-box-val { color: var(--green); text-shadow: 0 0 10px var(--green-glow); }

/* QUIZ FORM */
#quiz-form-panel {
  background: var(--bg-panel);
  border: 1px solid var(--border-gold);
  border-top: 2px solid var(--gold);
  padding: 1rem 1.2rem;
  position: relative;
  clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  backdrop-filter: blur(10px);
  box-shadow: 0 0 30px rgba(255,215,0,0.06), inset 0 0 40px rgba(0,0,0,0.3);
  animation: panelSlideIn 0.5s cubic-bezier(0.16,1,0.3,1);
}
@keyframes panelSlideIn { from{opacity:0;transform:translateY(-16px)} to{opacity:1;transform:translateY(0)} }

#quiz-form-panel::before {
  content: '';
  position: absolute; top: 0; left: 1.2rem; right: 1.2rem; height: 2px;
  background: linear-gradient(90deg, var(--gold), var(--red), var(--gold));
  background-size: 200% 100%;
  animation: topFlow 4s linear infinite;
}
@keyframes topFlow { 0%{background-position:0%} 100%{background-position:200%} }

.form-row { display: flex; gap: 0.7rem; margin-bottom: 0.7rem; }
.form-row:last-child { margin-bottom: 0; }

.neon-input {
  font-family: var(--font-body); font-size: 0.9rem; font-weight: 600;
  background: rgba(0,0,0,0.4);
  border: 1px solid var(--border-blue);
  color: var(--text-primary);
  padding: 0.6rem 0.8rem;
  outline: none; width: 100%;
  transition: all 0.2s;
  clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
}
.neon-input::placeholder { color: var(--text-dim); font-size: 0.82rem; }
.neon-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 15px var(--blue-glow), inset 0 0 8px rgba(0,212,255,0.05);
}
textarea.neon-input { resize: none; height: 70px; font-size: 0.9rem; }

.opt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; flex: 1; }

.opt-input-wrap {
  display: flex; align-items: center; gap: 0.4rem;
}
.opt-label {
  font-family: var(--font-hud); font-size: 0.75rem;
  width: 22px; height: 22px; border-radius: 2px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border-blue);
  color: var(--blue); background: rgba(0,212,255,0.06);
  flex-shrink: 0;
  cursor: pointer; transition: all 0.15s;
}
.opt-label.selected-ans {
  background: var(--green); color: #000; border-color: var(--green);
  box-shadow: 0 0 10px var(--green);
}
.opt-label:hover:not(.selected-ans) { border-color: var(--blue); background: rgba(0,212,255,0.12); }

.diff-toggle { display: flex; gap: 0.4rem; }
.diff-btn {
  font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.08em;
  padding: 0.35rem 0.7rem; background: transparent; cursor: pointer;
  border: 1px solid; border-radius: 1px; transition: all 0.15s;
  clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
}
.diff-btn.easy { border-color: rgba(0,255,136,0.3); color: var(--green); }
