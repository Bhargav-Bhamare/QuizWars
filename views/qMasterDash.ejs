<script>
// ─── CANVAS ──────────────────────────────────────────────────────────
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
function resizeCanvas() { canvas.width = innerWidth; canvas.height = innerHeight; }
resizeCanvas(); window.addEventListener('resize', resizeCanvas);

class Particle {
  constructor() { this.reset(); }
  reset() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * canvas.height;
    this.vx = (Math.random()-0.5) * 0.4;
    this.vy = -Math.random() * 0.6 - 0.1;
    this.alpha = Math.random() * 0.5 + 0.1;
    this.size = Math.random() * 1.8 + 0.4;
    const r = Math.random();
    this.color = r < 0.35 ? '#ffd700' : r < 0.6 ? '#ff2244' : '#00d4ff';
    this.life = 1; this.decay = Math.random() * 0.003 + 0.001;
  }
  tick() {
    this.x += this.vx; this.y += this.vy; this.life -= this.decay;
    this.alpha = this.life * 0.45;
    if (this.life <= 0) this.reset();
    ctx.save(); ctx.globalAlpha = this.alpha;
    ctx.fillStyle = this.color; ctx.shadowColor = this.color; ctx.shadowBlur = 7;
    ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }
}
const sparks = [];
const baseParticles = Array.from({length: 70}, () => new Particle());

function spawnSpark(x, y, color, n=10) {
  for (let i=0;i<n;i++) sparks.push({ x, y, vx:(Math.random()-0.5)*7, vy:(Math.random()-0.5)*7-2, alpha:1, size:Math.random()*3+1, color, life:1, decay:0.035+Math.random()*0.035 });
}

function draw() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const g = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 0, canvas.width/2, canvas.height/2, canvas.width*0.65);
  g.addColorStop(0,'rgba(0,25,50,0.12)'); g.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle = g; ctx.fillRect(0,0,canvas.width,canvas.height);
  [['#ffd700',0,0],['#ff2244',canvas.width,0],['#00d4ff',canvas.width/2,canvas.height]].forEach(([c,cx,cy])=>{
    const gg=ctx.createRadialGradient(cx,cy,0,cx,cy,180);
    gg.addColorStop(0,c+'14'); gg.addColorStop(1,'transparent');
    ctx.fillStyle=gg; ctx.fillRect(0,0,canvas.width,canvas.height);
  });
  baseParticles.forEach(p => p.tick());
  for (let i = sparks.length-1; i>=0; i--) {
    const s = sparks[i];
    s.x+=s.vx; s.y+=s.vy; s.vy+=0.12; s.life-=s.decay; s.alpha=s.life;
    if(s.life<=0){sparks.splice(i,1);continue;}
    ctx.save(); ctx.globalAlpha=s.alpha; ctx.fillStyle=s.color; ctx.shadowColor=s.color; ctx.shadowBlur=10;
    ctx.beginPath(); ctx.arc(s.x,s.y,s.size,0,Math.PI*2); ctx.fill(); ctx.restore();
  }
  requestAnimationFrame(draw);
}
draw();

// ─── DATA ─────────────────────────────────────────────────────────────
let questions = [
  { id:1, q:"What does CPU stand for?", opts:["Central Processing Unit","Central Program Utility","Computer Personal Unit","Core Processor Unit"], ans:0, diff:"easy" },
  { id:2, q:"Which data structure uses LIFO?", opts:["Queue","Stack","Linked List","Tree"], ans:1, diff:"easy" },
  { id:3, q:"Time complexity of Binary Search?", opts:["O(n)","O(n²)","O(log n)","O(1)"], ans:2, diff:"medium" },
  { id:4, q:"Which language is the 'mother of all languages'?", opts:["C","FORTRAN","COBOL","Assembly"], ans:0, diff:"medium" },
  { id:5, q:"Which sorting is O(n log n) average?", opts:["Bubble Sort","Insertion Sort","Merge Sort","Selection Sort"], ans:2, diff:"hard" },
  { id:6, q:"What does HTML stand for?", opts:["Hyper Text Markup Language","High Tech Modern Language","Hyper Transfer Markup Language","Home Text Markup Language"], ans:0, diff:"easy" },
  { id:7, q:"Python output of 2**10?", opts:["20","100","1024","512"], ans:2, diff:"medium" },
  { id:8, q:"Protocol for sending emails?", opts:["HTTP","FTP","SMTP","TCP"], ans:2, diff:"medium" },
  { id:9, q:"What is a deadlock?", opts:["A virus","CPU stops","Two processes wait indefinitely","Disk failure"], ans:2, diff:"hard" },
  { id:10, q:"Who developed Java?", opts:["Microsoft","Apple","Sun Microsystems","IBM"], ans:2, diff:"easy" },
];
let nextId = 11;

const players = [
  { name:"CADET_BHARGAV", emoji:"🦁", score:0, status:"pending" },
  { name:"BLITZ_NEHA",  emoji:"🐯", score:0, status:"pending" },
  { name:"CYBER_ROHAN", emoji:"🦊", score:0, status:"pending" },
  { name:"NOVA_PRIYA",  emoji:"🐺", score:0, status:"pending" },
  { name:"STORM_KARAN", emoji:"🦅", score:0, status:"pending" },
  { name:"ECHO_DIVYA",  emoji:"🐉", score:0, status:"pending" },
  { name:"VIPER_AMIT",  emoji:"🦁", score:0, status:"pending" },
];

let G = { running:false, paused:false, qIdx:0, timer:0, timerInt:null, editId:null, selectedAns:null, diff:'easy' };

// ─── FORM STATE ────────────────────────────────────────────────────────
function setAnswer(idx) {
  G.selectedAns = idx;
  const keys = ['A','B','C','D'];
  for (let i=0;i<4;i++) {
    const el = document.getElementById('lbl-'+i);
    el.className = 'opt-label' + (i===idx ? ' selected-ans' : '');
  }
  document.getElementById('ans-indicator').textContent = keys[idx];
}

function setDiff(d) {
  G.diff = d;
  ['easy','medium','hard'].forEach(x => document.getElementById('diff-'+x.replace('medium','med')).classList.toggle('active', x===d));
  // also handle correctly
  document.getElementById('diff-easy').classList.toggle('active', d==='easy');
  document.getElementById('diff-med').classList.toggle('active', d==='medium');
  document.getElementById('diff-hard').classList.toggle('active', d==='hard');
}

function clearForm() {
  document.getElementById('f-question').value = '';
  ['f-opt0','f-opt1','f-opt2','f-opt3'].forEach(id => document.getElementById(id).value = '');
  G.selectedAns = null; G.editId = null;
  for(let i=0;i<4;i++) document.getElementById('lbl-'+i).className = 'opt-label';
  document.getElementById('ans-indicator').textContent = '—';
  setDiff('easy');
}

function addQuestion(e) {
  const q = document.getElementById('f-question').value.trim();
  const opts = [0,1,2,3].map(i => document.getElementById('f-opt'+i).value.trim());
  if (!q || opts.some(o=>!o) || G.selectedAns===null) { notify('Fill all fields & select correct answer!','e'); return; }
  const newQ = { id:nextId++, q, opts, ans:G.selectedAns, diff:G.diff };
  questions.push(newQ);
  renderQBank();
  const btn = document.getElementById('btn-add-q');
  btn.classList.add('success'); setTimeout(()=>btn.classList.remove('success'),700);
  spawnSpark(window.innerWidth/2, window.innerHeight*0.4,'#00ff88',14);
  notify('✚ Question added to bank!','s');
  logEvent(`New question added: "${q.substring(0,30)}..."`, 'system');
  updateStats();
  clearForm();
}

function updateQuestion(e) {
  if (!G.editId) { notify('Select a question to edit first','w'); return; }
  const q = document.getElementById('f-question').value.trim();
  const opts = [0,1,2,3].map(i => document.getElementById('f-opt'+i).value.trim());
  if (!q || opts.some(o=>!o) || G.selectedAns===null) { notify('Fill all fields!','e'); return; }
  const idx = questions.findIndex(x=>x.id===G.editId);
  if (idx<0) return;
  questions[idx] = { ...questions[idx], q, opts, ans:G.selectedAns, diff:G.diff };
  renderQBank();
  notify('↺ Question updated!','i');
  logEvent(`Question #${G.editId} updated`, 'system');
  clearForm();
}

function editQuestion(id) {
  const q = questions.find(x=>x.id===id);
  if (!q) return;
  G.editId = id;
  document.getElementById('f-question').value = q.q;
  [0,1,2,3].forEach(i => document.getElementById('f-opt'+i).value = q.opts[i]);
  setAnswer(q.ans);
  setDiff(q.diff);
  notify('Editing question #'+id,'i');
}

function deleteQuestion(id) {
  const card = document.getElementById('qbc-'+id);
  if (card) { card.classList.add('deleting'); setTimeout(()=>{ questions = questions.filter(x=>x.id!==id); renderQBank(); updateStats(); }, 400); }
  spawnSpark(window.innerWidth*0.13, window.innerHeight*0.5,'#ff2244',10);
  notify('✕ Question deleted','e');
  logEvent(`Question #${id} removed from bank`, 'warn');
}

function renderQBank() {
  const list = document.getElementById('qbank-list');
  list.innerHTML = questions.map(q => `
    <div class="qb-card" id="qbc-${q.id}" onclick="editQuestion(${q.id})">
      <div class="qb-text">${q.q}</div>
      <div class="qb-meta">
        <span class="diff-badge diff-${q.diff}">${q.diff.toUpperCase()}</span>
        <div class="qb-actions" onclick="event.stopPropagation()">
          <button class="qb-btn qb-btn-edit" onclick="editQuestion(${q.id})">EDIT</button>
          <button class="qb-btn qb-btn-del" onclick="deleteQuestion(${q.id})">DEL</button>
        </div>
      </div>
    </div>
  `).join('');
}

// ─── LEADERBOARD ───────────────────────────────────────────────────────
function renderLeaderboard() {
  const sorted = [...players].sort((a,b)=>b.score-a.score);
  const max = sorted[0].score || 1;
  document.getElementById('lb-list').innerHTML = sorted.map((p,i) => {
    const rk = ['rk1','rk2','rk3'][i]||'rkn';
    const r1 = i===0?'r1':'';
    const pct = Math.round((p.score/max)*100);
    return `<div class="lb-row ${r1}">
      <div class="lb-rank ${rk}">${i+1}</div>
      <div class="lb-ava">${p.emoji}</div>
      <div class="lb-name">${p.name}</div>
      <div class="lb-score">${p.score}</div>
      <div class="lb-bar" style="width:${pct}%"></div>
    </div>`;
  }).join('');
}

// ─── PLAYER MONITOR ────────────────────────────────────────────────────
function renderPlayers() {
  document.getElementById('player-grid').innerHTML = players.map((p,i) => `
    <div class="player-card ${p.status}" style="animation-delay:${i*0.05}s">
      <div class="pc-emoji">${p.emoji}</div>
      <div class="pc-name">${p.name}</div>
      <div class="pc-status s-${p.status}">${p.status.toUpperCase()}</div>
    </div>
  `).join('');
}

// ─── EVENT LOG ─────────────────────────────────────────────────────────
function logEvent(msg, type='system') {
  const stream = document.getElementById('log-stream');
  const now = new Date();
  const ts = `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}:${now.getSeconds().toString().padStart(2,'0')}`;
  const map = { correct:'log-correct', wrong:'log-wrong', system:'log-system', warn:'log-warn' };
  const el = document.createElement('div');
  el.className = `log-entry ${map[type]||'log-system'}`;
  el.innerHTML = `<span class="log-time">[${ts}]</span>${msg}`;
  stream.appendChild(el);
  stream.scrollTop = stream.scrollHeight;
  if (stream.children.length > 60) stream.removeChild(stream.firstChild);
}

// ─── STATS ─────────────────────────────────────────────────────────────
function updateStats() {
  const tp = players.length;
  const avgScore = tp > 0 ? Math.round(players.reduce((s,p)=>s+p.score,0)/tp) : 0;
  document.getElementById('stat-total-q').textContent = questions.length;
  document.getElementById('stat-players').textContent = tp;
  document.getElementById('stat-accuracy').textContent = G.running ? Math.round(Math.random()*40+55)+'%' : '—';
  document.getElementById('stat-time').textContent = G.running ? G.timer+'s' : '—';
  document.getElementById('active-players-val').textContent = tp;
  document.getElementById('avg-score-val').textContent = avgScore || '—';
  document.getElementById('q-progress-val').textContent = G.running ? `${G.qIdx+1} / ${questions.length}` : '— / —';
  document.getElementById('sb-total').textContent = questions.length;
  document.getElementById('sb-players').textContent = tp;
  document.getElementById('sb-avg').textContent = avgScore || '—';
  document.getElementById('sb-progress').style.width = G.running ? `${((G.qIdx)/questions.length)*100}%` : '0%';
}

// ─── ARENA STATE ───────────────────────────────────────────────────────
function setArenaState(state) {
  const statusEl = document.getElementById('arena-status-val');
  const navPill = document.getElementById('nav-status');
  const navTxt = document.getElementById('status-txt');
  const sbState = document.getElementById('sb-state');
  if (state==='live') {
    statusEl.textContent='LIVE'; statusEl.className='state-val val-live';
    navPill.className='nav-status-pill live'; navTxt.textContent='LIVE';
    sbState.textContent='LIVE'; sbState.style.color='var(--red)';
  } else if (state==='paused') {
    statusEl.textContent='PAUSED'; statusEl.className='state-val val-waiting';
    navPill.className='nav-status-pill online'; navTxt.textContent='PAUSED';
    sbState.textContent='PAUSED'; sbState.style.color='var(--gold)';
  } else if (state==='finished') {
    statusEl.textContent='FINISHED'; statusEl.className='state-val val-finished';
    navPill.className='nav-status-pill offline'; navTxt.textContent='FINISHED';
    sbState.textContent='FINISHED'; sbState.style.color='var(--text-dim)';
  } else {
    statusEl.textContent='STANDBY'; statusEl.className='state-val val-waiting';
    navPill.className='nav-status-pill online'; navTxt.textContent='ONLINE';
    sbState.textContent='STANDBY'; sbState.style.color='var(--text-dim)';
  }
}

// ─── CONTROLS ──────────────────────────────────────────────────────────
function handleStart(e) {
  if (G.running && !G.paused) return;
  ripple(document.getElementById('btn-start'), e);

  if (G.paused) {
    G.paused = false;
    setArenaState('live');
    startQuestionTimer();
    notify('▶ Battle resumed!', 's');
    logEvent('Arena resumed by QuizMaster', 'system');
    return;
  }

  // Show launch animation
  const lo = document.getElementById('launch-overlay');
  lo.classList.add('visible');
  setTimeout(() => {
    lo.classList.remove('visible');
    G.running = true; G.qIdx = 0;
    players.forEach(p => { p.score=0; p.status='pending'; });
    renderLeaderboard(); renderPlayers();
    setArenaState('live');
    document.getElementById('btn-start').textContent = '▶ RESUME';
    document.getElementById('btn-pause').disabled = false;
    document.getElementById('btn-end').disabled = false;
    document.getElementById('btn-start').disabled = true;
    startQuestionTimer();
    logEvent('⚔ ARENA LAUNCHED — Battle has begun!', 'system');
    notify('⚔ Arena is LIVE! Battle started!', 's');
    spawnSpark(innerWidth/2, innerHeight/2,'#ffd700',25);
    updateStats();
    // Bot simulation
    clearInterval(window._botTick);
    window._botTick = setInterval(botTick, 3200);
  }, 2200);
}

function handlePause(e) {
  if (!G.running) return;
  ripple(document.getElementById('btn-pause'), e);
  if (!G.paused) {
    G.paused = true;
    clearInterval(G.timerInt);
    setArenaState('paused');
    document.getElementById('btn-start').disabled = false;
    document.getElementById('btn-start').textContent = '▶ RESUME';
    notify('⏸ Battle paused', 'w');
    logEvent('Arena PAUSED by QuizMaster', 'warn');
  } else {
    handleStart(e);
  }
}

function handleEnd(e) {
  if (!G.running) return;
  ripple(document.getElementById('btn-end'), e);
  G.running = false; G.paused = false;
  clearInterval(G.timerInt); clearInterval(window._botTick);
  setArenaState('finished');
  document.getElementById('btn-start').disabled = false;
  document.getElementById('btn-start').textContent = '▶ LAUNCH ARENA';
  document.getElementById('btn-pause').disabled = true;
  document.getElementById('btn-end').disabled = true;
  const sorted = [...players].sort((a,b)=>b.score-a.score);
  notify(`🏆 Game Over! Winner: ${sorted[0].name}`, 'w');
  logEvent(`⚔ BATTLE ENDED — Winner: ${sorted[0].name} (${sorted[0].score} pts)`, 'system');
  spawnSpark(innerWidth/2, innerHeight*0.3,'#ffd700',30);
  setTimeout(()=>spawnSpark(innerWidth*0.3, innerHeight*0.5,'#00d4ff',15),250);
  setTimeout(()=>spawnSpark(innerWidth*0.7, innerHeight*0.5,'#ff2244',15),500);
  updateStats();
}

function handleReset(e) {
  G.running=false; G.paused=false; G.qIdx=0;
  clearInterval(G.timerInt); clearInterval(window._botTick);
  players.forEach(p=>{p.score=0;p.status='pending';});
  setArenaState('standby');
  document.getElementById('btn-start').disabled=false;
  document.getElementById('btn-start').textContent='▶ LAUNCH ARENA';
  document.getElementById('btn-pause').disabled=true;
  document.getElementById('btn-end').disabled=true;
  renderLeaderboard(); renderPlayers();
  notify('⟳ Arena reset!','i');
  logEvent('Arena RESET by QuizMaster','warn');
  spawnSpark(innerWidth/2,innerHeight/2,'#ff2244',15);
  updateStats();
}

// ─── TIMER ─────────────────────────────────────────────────────────────
function startQuestionTimer() {
  clearInterval(G.timerInt);
  G.timer = 20;
  document.getElementById('stat-time').textContent = G.timer+'s';
  G.timerInt = setInterval(() => {
    G.timer--;
    document.getElementById('stat-time').textContent = G.timer+'s';
    if (G.timer <= 0) {
      clearInterval(G.timerInt);
      advanceQuestion();
    }
  }, 1000);
}

function advanceQuestion() {
  if (!G.running || G.paused) return;
  players.forEach(p => {
    if (p.status==='pending') { p.status='timeout'; logEvent(`${p.name} timed out on Q${G.qIdx+1}!`,'wrong'); }
  });
  G.qIdx++;
  if (G.qIdx >= questions.length) { handleEnd({clientX:0,clientY:0}); return; }
  players.forEach(p => p.status='pending');
  logEvent(`📋 Question ${G.qIdx+1} is now LIVE`, 'system');
  renderPlayers(); updateStats(); renderLeaderboard();
  startQuestionTimer();
  document.getElementById('sb-progress').style.width = `${(G.qIdx/questions.length)*100}%`;
  // Highlight active question in bank
  document.querySelectorAll('.qb-card').forEach((el,i) => el.classList.toggle('active-q', i===G.qIdx));
}

// ─── BOT SIMULATION ────────────────────────────────────────────────────
function botTick() {
  if (!G.running || G.paused) return;
  const pending = players.filter(p=>p.status==='pending');
  if (pending.length===0) return;
  const p = pending[Math.floor(Math.random()*pending.length)];
  const correct = Math.random() > 0.35;
  p.status = 'answered';
  if (correct) {
    p.score += Math.floor(Math.random()*100)+50;
    logEvent(`${p.name} answered CORRECTLY! +${Math.floor(Math.random()*100)+50} pts`,'correct');
    spawnSpark(innerWidth-160, innerHeight*0.55,'#00ff88',5);
  } else {
    logEvent(`${p.name} answered WRONG ✗`,'wrong');
  }
  renderPlayers(); renderLeaderboard(); updateStats();
}

// ─── RIPPLE ────────────────────────────────────────────────────────────
function ripple(btn, e) {
  if(!btn||!e) return;
  const r=btn.getBoundingClientRect();
  btn.style.setProperty('--rx',(e.clientX-r.left)+'px');
  btn.style.setProperty('--ry',(e.clientY-r.top)+'px');
  btn.classList.remove('rippling'); btn.offsetHeight; btn.classList.add('rippling');
  setTimeout(()=>btn.classList.remove('rippling'),500);
}

// ─── NOTIFY ────────────────────────────────────────────────────────────
function notify(msg, type='i') {
  const zone = document.getElementById('notif-zone');
  const el = document.createElement('div');
  el.className = `notif ${type}`; el.textContent = msg;
  zone.appendChild(el);
  setTimeout(()=>el.remove(), 2700);
}

// ─── INIT ──────────────────────────────────────────────────────────────
renderQBank();
renderLeaderboard();
renderPlayers();
updateStats();

setTimeout(() => {
  setArenaState('standby');
  logEvent('Control Room initialized', 'system');
  logEvent('Quiz bank loaded: ' + questions.length + ' questions', 'system');
  logEvent('Players registered: ' + players.length, 'system');
  logEvent('Awaiting QuizMaster to LAUNCH ARENA...', 'warn');
  notify('⚔ Control Room ready. Launch when set!','s');
}, 4200);

// Live idle bot chatter
setInterval(()=>{
  if(!G.running){
    const msgs=[`Player ${players[Math.floor(Math.random()*players.length)].name} is in lobby`,'All systems nominal','Arena weapons charged','Awaiting battle signal'];
    logEvent(msgs[Math.floor(Math.random()*msgs.length)],'system');
  }
}, 7000);
</script>
