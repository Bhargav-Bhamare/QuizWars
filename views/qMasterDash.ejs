}
.notif.s { background: rgba(0,255,136,0.09); border-color: var(--green); color: var(--green); }
.notif.e { background: rgba(255,34,68,0.09); border-color: var(--red); color: var(--red); }
.notif.i { background: rgba(0,212,255,0.08); border-color: var(--blue); color: var(--blue); }
.notif.w { background: rgba(255,215,0,0.08); border-color: var(--gold); color: var(--gold); }
@keyframes notifIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
@keyframes notifOut { to{opacity:0;transform:translateX(20px)} }

/* ─── MISC ───────────────────────────────── */
.hidden { display: none !important; }

.panel-title {
  font-family: var(--font-hud); font-size: 0.58rem; letter-spacing: 0.25em;
  color: var(--blue); text-shadow: 0 0 6px var(--blue-glow);
  margin-bottom: 0.7rem;
  display: flex; align-items: center; gap: 0.4rem;
}
.panel-title::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--blue-glow), transparent); }

.glitch-txt {
  animation: glitch 3s ease-in-out infinite;
}
@keyframes glitch {
  0%,90%,100%{text-shadow:0 0 10px var(--red)}
  91%{text-shadow:-2px 0 var(--blue),2px 0 var(--gold);transform:skewX(2deg)}
  93%{text-shadow:2px 0 var(--blue),-2px 0 var(--gold);transform:skewX(-1deg)}
  95%{text-shadow:0 0 10px var(--red);transform:skewX(0)}
}
</style>
</head>
<body>

